{
  "ci": {
    "collect": {
      "url": ["http://localhost:3000"],
      "startServerCommand": "yarn start",
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }]
      }
    }
  }
}
